/* ================================================================
   ALAS — Dark Theme Stylesheet
   Professional dark theme with violet accents
   ================================================================ */

/* --- Global --- */
QWidget {
    background-color: #1a1a2e;
    color: #e0e0e8;
    font-family: "Segoe UI", "Inter", "Roboto", sans-serif;
    font-size: 13px;
    selection-background-color: #7c3aed;
    selection-color: #ffffff;
}

/* --- Main Window --- */
QMainWindow {
    background-color: #1a1a2e;
}

QMainWindow::separator {
    background-color: #2a2a3d;
    width: 2px;
    height: 2px;
}

QMainWindow::separator:hover {
    background-color: #7c3aed;
}

/* --- Menu Bar --- */
QMenuBar {
    background-color: #16162a;
    border-bottom: 1px solid #2a2a3d;
    padding: 2px 0;
}

QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
    border-radius: 4px;
    margin: 2px 1px;
}

QMenuBar::item:selected {
    background-color: #2a2a3d;
}

QMenuBar::item:pressed {
    background-color: #7c3aed;
    color: #ffffff;
}

/* --- Menus --- */
QMenu {
    background-color: #1e1e32;
    border: 1px solid #3a3a4d;
    border-radius: 8px;
    padding: 6px 0;
}

QMenu::item {
    padding: 8px 32px 8px 24px;
    border-radius: 4px;
    margin: 2px 6px;
}

QMenu::item:selected {
    background-color: #7c3aed;
    color: #ffffff;
}

QMenu::item:disabled {
    color: #555568;
}

QMenu::separator {
    height: 1px;
    background-color: #2a2a3d;
    margin: 4px 12px;
}

QMenu::indicator {
    width: 16px;
    height: 16px;
    margin-left: 6px;
}

/* --- Toolbar --- */
QToolBar {
    background-color: #16162a;
    border-bottom: 1px solid #2a2a3d;
    padding: 4px 8px;
    spacing: 4px;
}

QToolBar::separator {
    width: 1px;
    background-color: #3a3a4d;
    margin: 4px 6px;
}

QToolButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 6px 10px;
    color: #c0c0d0;
    font-weight: 500;
}

QToolButton:hover {
    background-color: #2a2a3d;
    border-color: #3a3a4d;
    color: #e0e0e8;
}

QToolButton:pressed {
    background-color: #7c3aed;
    color: #ffffff;
}

QToolButton:checked {
    background-color: #5b21b6;
    border-color: #7c3aed;
    color: #ffffff;
}

/* --- Dock Widgets --- */
QDockWidget {
    titlebar-close-icon: none;
    titlebar-normal-icon: none;
    color: #c0c0d0;
    font-weight: 600;
    font-size: 12px;
}

QDockWidget::title {
    background-color: #1e1e32;
    border: 1px solid #2a2a3d;
    border-bottom: 2px solid #7c3aed;
    padding: 8px 12px;
    text-align: left;
}

QDockWidget::close-button,
QDockWidget::float-button {
    background-color: transparent;
    border: none;
    padding: 2px;
}

QDockWidget::close-button:hover,
QDockWidget::float-button:hover {
    background-color: #2a2a3d;
    border-radius: 4px;
}

/* --- Tab Widget --- */
QTabWidget::pane {
    background-color: #1e1e32;
    border: 1px solid #2a2a3d;
    border-top: 2px solid #7c3aed;
    border-radius: 0 0 6px 6px;
}

QTabBar::tab {
    background-color: #16162a;
    border: 1px solid #2a2a3d;
    border-bottom: none;
    padding: 8px 16px;
    margin-right: 2px;
    border-radius: 6px 6px 0 0;
    color: #888898;
    font-weight: 500;
}

QTabBar::tab:selected {
    background-color: #1e1e32;
    border-bottom: 2px solid #7c3aed;
    color: #e0e0e8;
}

QTabBar::tab:hover:!selected {
    background-color: #22223a;
    color: #c0c0d0;
}

/* --- Push Button --- */
QPushButton {
    background-color: #2a2a3d;
    border: 1px solid #3a3a4d;
    border-radius: 6px;
    padding: 8px 20px;
    color: #e0e0e8;
    font-weight: 500;
    min-height: 18px;
}

QPushButton:hover {
    background-color: #353550;
    border-color: #7c3aed;
}

QPushButton:pressed {
    background-color: #7c3aed;
    color: #ffffff;
}

QPushButton:disabled {
    background-color: #1e1e32;
    color: #555568;
    border-color: #2a2a3d;
}

QPushButton#primary {
    background-color: #7c3aed;
    border-color: #8b5cf6;
    color: #ffffff;
}

QPushButton#primary:hover {
    background-color: #8b5cf6;
}

QPushButton#primary:pressed {
    background-color: #6d28d9;
}

QPushButton#danger {
    background-color: #dc2626;
    border-color: #ef4444;
    color: #ffffff;
}

QPushButton#danger:hover {
    background-color: #ef4444;
}

/* --- Line Edit --- */
QLineEdit {
    background-color: #16162a;
    border: 1px solid #3a3a4d;
    border-radius: 6px;
    padding: 8px 12px;
    color: #e0e0e8;
}

QLineEdit:focus {
    border-color: #7c3aed;
    background-color: #1a1a30;
}

QLineEdit:disabled {
    background-color: #1a1a2e;
    color: #555568;
}

/* --- Spin Box / Double Spin Box --- */
QSpinBox, QDoubleSpinBox {
    background-color: #16162a;
    border: 1px solid #3a3a4d;
    border-radius: 6px;
    padding: 6px 10px;
    color: #e0e0e8;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #7c3aed;
}

QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    background-color: #2a2a3d;
    border: none;
    width: 20px;
    border-radius: 3px;
}

QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #7c3aed;
}

/* --- Combo Box --- */
QComboBox {
    background-color: #16162a;
    border: 1px solid #3a3a4d;
    border-radius: 6px;
    padding: 8px 12px;
    color: #e0e0e8;
    min-width: 120px;
}

QComboBox:hover {
    border-color: #7c3aed;
}

QComboBox::drop-down {
    border: none;
    width: 28px;
    background-color: #2a2a3d;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
}

QComboBox QAbstractItemView {
    background-color: #1e1e32;
    border: 1px solid #3a3a4d;
    border-radius: 6px;
    selection-background-color: #7c3aed;
    selection-color: #ffffff;
    padding: 4px;
}

/* --- Scroll Bar --- */
QScrollBar:vertical {
    background-color: #16162a;
    width: 10px;
    border-radius: 5px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: #3a3a4d;
    min-height: 30px;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background-color: #7c3aed;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background-color: #16162a;
    height: 10px;
    border-radius: 5px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: #3a3a4d;
    min-width: 30px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #7c3aed;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0;
}

/* --- Progress Bar --- */
QProgressBar {
    background-color: #16162a;
    border: 1px solid #2a2a3d;
    border-radius: 6px;
    text-align: center;
    color: #e0e0e8;
    height: 18px;
    font-size: 11px;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #7c3aed, stop:1 #a855f7);
    border-radius: 5px;
}

/* --- Slider --- */
QSlider::groove:horizontal {
    background-color: #2a2a3d;
    height: 6px;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background-color: #7c3aed;
    width: 16px;
    height: 16px;
    margin: -5px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #a855f7;
}

QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #7c3aed, stop:1 #a855f7);
    border-radius: 3px;
}

/* --- Check Box --- */
QCheckBox {
    spacing: 8px;
    color: #e0e0e8;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3a3a4d;
    border-radius: 4px;
    background-color: #16162a;
}

QCheckBox::indicator:checked {
    background-color: #7c3aed;
    border-color: #7c3aed;
}

QCheckBox::indicator:hover {
    border-color: #7c3aed;
}

/* --- Group Box --- */
QGroupBox {
    border: 1px solid #2a2a3d;
    border-radius: 8px;
    margin-top: 16px;
    padding-top: 16px;
    font-weight: 600;
    color: #c0c0d0;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 4px 12px;
    background-color: #1e1e32;
    border: 1px solid #2a2a3d;
    border-radius: 4px;
    color: #a855f7;
}

/* --- Tree Widget --- */
QTreeWidget, QTreeView {
    background-color: #16162a;
    border: 1px solid #2a2a3d;
    border-radius: 6px;
    alternate-background-color: #1a1a30;
    outline: none;
}

QTreeWidget::item, QTreeView::item {
    padding: 6px 8px;
    border-radius: 4px;
    margin: 1px 4px;
}

QTreeWidget::item:selected, QTreeView::item:selected {
    background-color: #7c3aed;
    color: #ffffff;
}

QTreeWidget::item:hover, QTreeView::item:hover {
    background-color: #2a2a3d;
}

QTreeWidget::branch {
    background-color: transparent;
}

/* --- Header View --- */
QHeaderView::section {
    background-color: #1e1e32;
    border: 1px solid #2a2a3d;
    padding: 6px 10px;
    color: #a0a0b0;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
}

/* --- Table --- */
QTableWidget, QTableView {
    background-color: #16162a;
    border: 1px solid #2a2a3d;
    border-radius: 6px;
    gridline-color: #2a2a3d;
    alternate-background-color: #1a1a30;
}

QTableWidget::item:selected, QTableView::item:selected {
    background-color: #7c3aed;
    color: #ffffff;
}

/* --- Tooltip --- */
QToolTip {
    background-color: #1e1e32;
    border: 1px solid #7c3aed;
    border-radius: 6px;
    padding: 6px 10px;
    color: #e0e0e8;
    font-size: 12px;
}

/* --- Status Bar --- */
QStatusBar {
    background-color: #16162a;
    border-top: 1px solid #2a2a3d;
    color: #a0a0b0;
    font-size: 12px;
}

QStatusBar::item {
    border: none;
}

/* --- Splitter --- */
QSplitter::handle {
    background-color: #2a2a3d;
}

QSplitter::handle:hover {
    background-color: #7c3aed;
}

QSplitter::handle:horizontal {
    width: 2px;
}

QSplitter::handle:vertical {
    height: 2px;
}

/* --- Text Edit / Plain Text --- */
QTextEdit, QPlainTextEdit {
    background-color: #12121f;
    border: 1px solid #2a2a3d;
    border-radius: 6px;
    padding: 8px;
    color: #c0c0d0;
    font-family: "JetBrains Mono", "Fira Code", "Consolas", monospace;
    font-size: 12px;
}

/* --- Label --- */
QLabel {
    background-color: transparent;
    color: #e0e0e8;
}

QLabel#heading {
    font-size: 16px;
    font-weight: 700;
    color: #ffffff;
}

QLabel#subheading {
    font-size: 13px;
    font-weight: 600;
    color: #a855f7;
}

QLabel#muted {
    color: #888898;
    font-size: 11px;
}

/* --- Dialog --- */
QDialog {
    background-color: #1a1a2e;
    border: 1px solid #2a2a3d;
    border-radius: 12px;
}

/* --- Radio Button --- */
QRadioButton {
    spacing: 8px;
    color: #e0e0e8;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #3a3a4d;
    border-radius: 9px;
    background-color: #16162a;
}

QRadioButton::indicator:checked {
    background-color: #7c3aed;
    border-color: #7c3aed;
}

QRadioButton::indicator:hover {
    border-color: #7c3aed;
}
